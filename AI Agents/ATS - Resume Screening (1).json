    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const j = item.json;\n\n  return {\n    json: {\n      ...j,\n      education: (j.education || [])\n        .map(e => `${e.degree} - ${e.institution} (${e.year})`)\n        .join(\"\\n\"),\n\n      technicalSkills: (j.technicalSkills || []).join(\", \"),\n      softSkills: (j.softSkills || []).join(\", \"),\n      projects: (j.projects || []).join(\", \"),\n      matchingSkills: (j.matchingSkills || []).join(\", \"),\n      missingSkills: (j.missingSkills || []).join(\", \"),\n      additionalSkills: (j.additionalSkills || []).join(\", \"),\n      strengths: (j.strengths || []).join(\"\\n\"),\n      weaknesses: (j.weaknesses || []).join(\"\\n\"),\n      certifications: (j.certifications || []).join(\", \")\n    }\n  };\n});"
      },
